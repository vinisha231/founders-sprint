{
  "name": "ship-guard",
  "version": "1.0.0",
  "description": "Build → Validate → Secure: scan a git diff for missing tests, code smells, and security issues before you ship.",
  "bin": {
    "ship-guard": "cli.js"
  },
  "main": "scanner.js",
  "type": "commonjs",
  "scripts": {
    "scan": "node cli.js",
    "scan:all": "node cli.js --all",
    "install-hook": "node install-hook.js",
    "test": "node test.js"
  },
  "files": [
    "scanner.js",
    "cli.js",
    "install-hook.js"
  ],
  "keywords": ["security", "sast", "git-hook", "pre-commit", "code-review", "ci"],
  "license": "MIT",
  "engines": {
    "node": ">=14"
  }
}
